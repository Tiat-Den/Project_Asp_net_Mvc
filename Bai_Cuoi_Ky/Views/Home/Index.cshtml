@model IEnumerable<Bai_Cuoi_Ky.Models.Product>
@{
    ViewData["Title"] = "Trang Chủ - DKH Premium Jewelry";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/home.css" asp-append-version="true" />

<div class="hero-slider">
    <div class="slide slide-1 active">
        <img class="slide-bg" src="/images/Favorite/banner4.jpg" alt="Banner 1" />
        <div class="slide-overlay"></div>
        <div class="slide-content">
            <h1 class="slide-title">Top Sản Phẩm<br /><span>Yêu Thích</span></h1>
            <a asp-controller="Product" asp-action="Index" class="slide-btn">Khám Phá Ngay</a>
        </div>
    </div>
    <div class="slide slide-2">
        <img class="slide-bg" src="/images/Favorite/banner3.jpg" alt="Banner 2" />
        <div class="slide-overlay"></div>
        <div class="slide-content">
            <h1 class="slide-title">BST Mới Nhất<br /><span>Trang Sức DKH</span></h1>
            <a asp-controller="Product" asp-action="Index" class="slide-btn">Xem Ngay</a>
        </div>
    </div>
    <button class="slider-prev" onclick="changeSlide(-1)">‹</button>
    <button class="slider-next" onclick="changeSlide(1)">›</button>
</div>

<div class="section">
    <div class="section-header"><h2 class="section-title">Xu Hướng Tìm Kiếm</h2></div>
    <div class="cat-grid">
        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="1" class="cat-card">
            <div class="cat-img"><img src="/images/Categories/Vong-Lac.jpg" alt="Vòng - Lắc" /></div>
            <div class="cat-name">Vòng - Lắc</div>
        </a>
        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="2" class="cat-card">
            <div class="cat-img"><img src="/images/Categories/Nhan.jpg" alt="Nhẫn" /></div>
            <div class="cat-name">Nhẫn</div>
        </a>
        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="3" class="cat-card">
            <div class="cat-img"><img src="/images/Categories/Day-chuyen.jpg" alt="Dây Chuyền" /></div>
            <div class="cat-name">Dây Chuyền</div>
        </a>
        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="4" class="cat-card">
            <div class="cat-img"><img src="/images/categories/Bong-tai.jpg" alt="Bông Tai" /></div>
            <div class="cat-name">Bông Tai</div>
        </a>
        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="5" class="cat-card">
            <div class="cat-img"><img src="/images/Categories/Trang-suc-doi.jpg" alt="Trang Sức Đôi" /></div>
            <div class="cat-name">Trang Sức Đôi</div>
        </a>
        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="6" class="cat-card">
            <div class="cat-img"><img src="/images/Categories/Trang-suc-bo.jpg" alt="Trang Sức Bộ" /></div>
            <div class="cat-name">Trang Sức Bộ</div>
        </a>
    </div>
</div>

<div class="trending-bg">
    <div class="section" style="padding-top:20px;padding-bottom:20px;">
        <div class="section-header">
            <h2 class="section-title" style="background:var(--gray);">Top Sản Phẩm Yêu Thích</h2>
        </div>
        <div class="product-grid">
            @foreach (var item in Model.Take(4))
            {
                <div class="p-card">
                    <div class="p-img-wrap">
                        <img class="p-img-main" src="@item.ImageUrl" alt="@item.Name" />
                        <img class="p-img-hover" src="@(string.IsNullOrEmpty(item.ImageUrl2) ? item.ImageUrl : item.ImageUrl2)" alt="@item.Name" />
                    </div>
                    <div class="p-body">
                        <div class="p-cat">@(item.Category?.Name ?? "Trang sức")</div>
                        <div class="p-name">@item.Name</div>
                        <div class="p-price">@item.Price.ToString("N0")₫</div>
                    </div>
                    <div class="p-actions"><a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">Xem Chi Tiết →</a></div>
                </div>
            }
        </div>
    </div>
</div>

<div class="section">
    <div class="section-header"><h2 class="section-title">Sản Phẩm Mới Nhất</h2></div>
    <div class="product-grid">
        @foreach (var item in Model.OrderByDescending(p => p.Id).Take(4))
        {
            <div class="p-card">
                <div class="p-badge new-badge">NEW</div>
                <div class="p-img-wrap">
                    <img class="p-img-main" src="@item.ImageUrl" alt="@item.Name" />
                    <img class="p-img-hover" src="@(string.IsNullOrEmpty(item.ImageUrl2) ? item.ImageUrl : item.ImageUrl2)" alt="@item.Name" />
                </div>
                <div class="p-body">
                    <div class="p-cat">@(item.Category?.Name ?? "New Arrival")</div>
                    <div class="p-name">@item.Name</div>
                    <div class="p-price">@item.Price.ToString("N0")₫</div>
                </div>
                <div class="p-actions"><a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">Xem Chi Tiết →</a></div>
            </div>
        }
    </div>
</div>

<div class="trending-bg">
    <div class="section" style="padding-top:20px;padding-bottom:20px;">
        <div class="section-header">
            <h2 class="section-title" style="background:var(--gray);">Sản Phẩm Khuyến Mãi</h2>
        </div>
        <div class="product-grid">
            @{
                var saleItems = Model.Where(p => p.DiscountPrice.HasValue && p.DiscountPrice > p.Price).Take(4);
            }
            @if (saleItems.Any())
            {
                @foreach (var item in saleItems)
                {
                    int percent = (int)((item.DiscountPrice.Value - item.Price) / item.DiscountPrice.Value * 100);
                    <div class="p-card">
                        <div class="sale-badge-wrap">
                            <span class="sale-tag">GIẢM</span>
                            <span class="sale-pct">@percent%</span>
                        </div>
                        <div class="p-img-wrap">
                            <img class="p-img-main" src="@item.ImageUrl" alt="@item.Name" />
                            <img class="p-img-hover" src="@(string.IsNullOrEmpty(item.ImageUrl2) ? item.ImageUrl : item.ImageUrl2)" alt="@item.Name" />
                        </div>
                        <div class="p-body">
                            <div class="p-cat">@(item.Category?.Name ?? "Sale")</div>
                            <div class="p-name">@item.Name</div>
                            <div class="price-row">
                                <span class="p-price">@item.Price.ToString("N0")₫</span>
                                <span class="p-price-old-2">@item.DiscountPrice?.ToString("N0")₫</span>
                            </div>
                        </div>
                        <div class="p-actions"><a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">Xem Chi Tiết →</a></div>
                    </div>
                }
            }
            else
            {
                <div style="grid-column: 1/-1; text-align: center; color: #888; padding: 40px;">Hiện chưa có sản phẩm khuyến mãi.</div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let current = 0;
        const slides = document.querySelectorAll('.slide');
        function changeSlide(dir) {
            slides[current].classList.remove('active');
            current = (current + dir + slides.length) % slides.length;
            slides[current].classList.add('active');
        }
        setInterval(() => changeSlide(1), 5000);
    </script>
}