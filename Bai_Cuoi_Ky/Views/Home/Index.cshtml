@{
    ViewData["Title"] = "Trang Chủ";
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --red: #c0392b;
        --gold: #c9a84c;
        --dark: #1a1410;
        --gray: #f5f5f5;
        --muted: #888;
        --border: #e8e8e8;
    }

    /* ===== HERO SLIDER ===== */
    .hero-slider {
        position: relative;
        overflow: hidden;
        height: 520px;
        background: #1a0a05;
    }

    .slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.8s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .slide.active {
            opacity: 1;
        }

    .slide-1 {
        background: linear-gradient(135deg, #8b1a0a 0%, #c0392b 40%, #6b2d0a 100%);
    }

    .slide-2 {
        background: linear-gradient(135deg, #1a1410 0%, #3d2b1a 40%, #c9a84c 100%);
    }

    .slide-3 {
        background: linear-gradient(135deg, #0a1a2b 0%, #1a3a5c 40%, #c9a84c 100%);
    }

    /* Nếu có ảnh nền */
    .slide-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    .slide-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.3);
        z-index: 1;
    }

    .slide-content {
        position: relative;
        z-index: 2;
        text-align: center;
        max-width: 600px;
        padding: 0 40px;
    }

    .slide-tag {
        font-size: 0.7rem;
        letter-spacing: 4px;
        text-transform: uppercase;
        color: rgba(255,255,255,0.7);
        margin-bottom: 16px;
    }

    .slide-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3.8rem;
        font-weight: 300;
        color: white;
        line-height: 1.1;
        margin-bottom: 20px;
        text-shadow: 0 2px 12px rgba(0,0,0,0.3);
    }

        .slide-title span {
            color: white;
        }

    .slide-desc {
        font-size: 0.9rem;
        color: white;
        line-height: 1.7;
        margin-bottom: 32px;
    }

    .slide-btn {
        display: inline-block;
        padding: 13px 38px;
        background: transparent;
        border: 2px solid white;
        color: white;
        font-family: 'Jost', sans-serif;
        font-size: 0.78rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.3s;
    }

        .slide-btn:hover {
            background: white;
            color: var(--dark);
            text-decoration: none;
        }

    .slide-deco {
        position: absolute;
        right: 80px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 12rem;
        opacity: 0.12;
        filter: blur(1px);
        z-index: 1;
    }

    .slider-prev, .slider-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        color: white;
        width: 46px;
        height: 46px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 1.4rem;
        z-index: 10;
        transition: background 0.2s;
    }

    .slider-prev {
        left: 20px;
    }

    .slider-next {
        right: 20px;
    }

        .slider-prev:hover, .slider-next:hover {
            background: rgba(255,255,255,0.3);
        }

    .slider-dots {
        position: absolute;
        bottom: 20px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 8px;
        z-index: 10;
    }

    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: rgba(255,255,255,0.4);
        cursor: pointer;
        transition: all 0.3s;
        border: none;
    }

        .dot.active {
            background: white;
            width: 24px;
            border-radius: 4px;
        }

    /* ===== SECTIONS ===== */
    .section {
        padding: 60px 40px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .section-header {
        text-align: center;
        margin-bottom: 40px;
        position: relative;
    }

        .section-header::before, .section-header::after {
            content: '';
            position: absolute;
            top: 50%;
            width: calc(50% - 160px);
            height: 1px;
            background: var(--border);
        }

        .section-header::before {
            left: 0;
        }

        .section-header::after {
            right: 0;
        }

    .section-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        font-weight: 400;
        color: var(--dark);
        letter-spacing: 4px;
        text-transform: uppercase;
        display: inline-block;
        padding: 0 24px;
        background: white;
        position: relative;
        z-index: 1;
    }

    /* ===== CATEGORY GRID ===== */
    .cat-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 16px;
    }

    .cat-card {
        text-align: center;
        cursor: pointer;
        transition: transform 0.25s;
        text-decoration: none;
    }

        .cat-card:hover {
            transform: translateY(-4px);
            text-decoration: none;
        }

    .cat-img {
        width: 100%;
        aspect-ratio: 1;
        border-radius: 12px;
        background: linear-gradient(135deg, #f5f0e8, #ede8de);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin-bottom: 10px;
        transition: box-shadow 0.25s;
        overflow: hidden;
    }

    .cat-card:hover .cat-img {
        box-shadow: 0 12px 32px rgba(0,0,0,0.12);
    }

    .cat-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .cat-name {
        font-size: 0.72rem;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--dark);
        font-weight: 500;
    }

    /* ===== PRODUCT GRID ===== */
    .trending-bg {
        background: var(--gray);
        padding: 40px 0 0 0;
    }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .p-card {
        background: white;
        position: relative;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .p-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 40px rgba(0,0,0,0.1);
        }

            .p-card:hover .p-actions {
                opacity: 1;
                bottom: 0;
            }

    .p-img {
        width: 100%;
        height: 240px;
        background: linear-gradient(135deg, #f5f0e8, #ede8de);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
    }

        .p-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .p-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        background: var(--red);
        color: white;
        font-size: 0.62rem;
        letter-spacing: 1px;
        padding: 3px 10px;
        text-transform: uppercase;
        font-weight: 500;
    }

        .p-badge.new-badge {
            background: var(--gold);
        }

    .p-body {
        padding: 16px;
    }

    .p-cat {
        font-size: 0.62rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 4px;
    }

    .p-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--dark);
        margin-bottom: 8px;
        line-height: 1.3;
    }

    .p-price {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--red);
    }

    .p-price-old {
        font-size: 0.78rem;
        color: #bbb;
        text-decoration: line-through;
        margin-left: 8px;
    }

    .p-actions {
        position: absolute;
        bottom: -48px;
        left: 0;
        right: 0;
        background: var(--dark);
        padding: 12px;
        text-align: center;
        opacity: 0;
        transition: all 0.3s;
    }

        .p-actions a {
            color: white;
            font-size: 0.72rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            text-decoration: none;
        }

            .p-actions a:hover {
                color: var(--gold);
            }
    /* ===== HOVER ĐỔI ẢNH ===== */
    .p-img-wrap {
        position: relative;
        width: 100%;
        height: 240px;
        overflow: hidden;
        display: block;
    }

    .p-img-main, .p-img-hover {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: opacity 0.5s ease;
        display: block;
    }

    .p-img-main {
        opacity: 1;
        z-index: 1;
    }

    .p-img-hover {
        opacity: 0;
        z-index: 2;
    }

    .p-card:hover .p-img-main {
        opacity: 0;
    }

    .p-card:hover .p-img-hover {
        opacity: 1;
    }

    /* ===== BANNER STRIP ===== */
    .banner-strip {
        background: linear-gradient(135deg, var(--red) 0%, #8b1a0a 100%);
        padding: 48px 40px;
        text-align: center;
    }

    .strip-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.4rem;
        font-weight: 300;
        color: white;
        letter-spacing: 4px;
        margin-bottom: 10px;
    }

    .strip-sub {
        font-size: 0.82rem;
        color: rgba(255,255,255,0.75);
        letter-spacing: 2px;
        margin-bottom: 28px;
    }

    .strip-btn {
        display: inline-block;
        padding: 12px 36px;
        background: white;
        color: var(--red);
        font-family: 'Jost', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }

        .strip-btn:hover {
            background: var(--gold);
            color: white;
            text-decoration: none;
        }
    /* ===== SALE BADGE ===== */
    .sale-badge-wrap {
        position: absolute;
        top: 0;
        left: 0;
        background: var(--red);
        color: white;
        width: 56px;
        padding: 8px 6px;
        text-align: center;
        clip-path: polygon(0 0, 100% 0, 100% 85%, 50% 100%, 0 85%);
        z-index: 10;
    }

    .sale-tag {
        display: block;
        font-size: 0.6rem;
        letter-spacing: 1px;
        font-weight: 600;
        text-transform: uppercase;
    }

    .sale-pct {
        display: block;
        font-size: 1.1rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .price-row {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .p-price-old-2 {
        font-size: 0.8rem;
        color: #aaa;
        text-decoration: line-through;
    }


</style>

