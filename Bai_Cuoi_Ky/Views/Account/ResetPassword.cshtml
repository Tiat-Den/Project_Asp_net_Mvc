@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div style="max-width: 500px; margin: 50px auto; padding: 20px; font-family: Arial, sans-serif;">
    <h2 style="text-align: center; margin-bottom: 30px; color: #1a1410; text-transform: uppercase; letter-spacing: 2px;">ĐẶT LẠI MẬT KHẨU</h2>

    <form asp-controller="Account" asp-action="ResetPassword" method="post" style="background: #fff; padding: 40px; border-radius: 8px; border: 1px solid #eaeaea; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="color: red; margin-bottom: 20px; text-align: center; font-size: 14px;">
                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
            </div>
        }

        <input type="hidden" name="Email" value="@ViewBag.Email" />
        <input type="hidden" name="Token" value="@ViewBag.Token" />

        <div style="margin-bottom: 25px;">
            <label style="font-weight: bold; color: #333; display: block; margin-bottom: 8px; font-size: 14px;">MẬT KHẨU MỚI</label>
            <div style="position: relative;">
                <input type="password" id="newPwd" name="NewPassword" required style="width: 100%; padding: 12px 40px 12px 15px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box; outline: none;" />
                <span onclick="togglePassword('newPwd', this)" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #999;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </span>
            </div>
        </div>

        <div style="margin-bottom: 30px;">
            <label style="font-weight: bold; color: #333; display: block; margin-bottom: 8px; font-size: 14px;">NHẬP LẠI MẬT KHẨU MỚI</label>
            <div style="position: relative;">
                <input type="password" id="confirmPwd" name="ConfirmPassword" required style="width: 100%; padding: 12px 40px 12px 15px; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box; outline: none;" />
                <span onclick="togglePassword('confirmPwd', this)" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #999;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </span>
            </div>
        </div>

        <div style="text-align: center; margin-top: 30px;">
            <button type="submit" style="width: 100%; background-color: #1a1410; color: white; padding: 14px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; letter-spacing: 1px; transition: background-color 0.2s;">XÁC NHẬN ĐỔI MẬT KHẨU</button>
        </div>
    </form>
</div>

<script>
    function togglePassword(inputId, iconSpan) {
        var input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
            iconSpan.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
        } else {
            input.type = "password";
            iconSpan.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
        }
    }
</script>