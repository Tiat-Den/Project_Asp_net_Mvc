@using Microsoft.AspNetCore.Identity
@model IdentityUser

@{
    ViewData["Title"] = "Thông tin tài khoản";
}

<div style="max-width: 800px; margin: 50px auto; padding: 20px; font-family: Arial, sans-serif;">
    <h2 style="text-align: center; margin-bottom: 30px; color: #1a1410; text-transform: uppercase; letter-spacing: 2px;">THÔNG TIN TÀI KHOẢN</h2>

    <div style="background: #fff; padding: 40px; border-radius: 8px; border: 1px solid #eaeaea; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
        <div style="margin-bottom: 25px;">
            <label style="font-weight: bold; color: #333; display: block; margin-bottom: 8px; font-size: 14px;">TÊN ĐĂNG NHẬP</label>
            <input type="text" value="@Model.UserName" readonly style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 4px; background-color: #f8f9fa; color: #555; box-sizing: border-box; outline: none;" />
        </div>

        <div style="margin-bottom: 25px;">
            <label style="font-weight: bold; color: #333; display: block; margin-bottom: 8px; font-size: 14px;">EMAIL</label>
            <input type="email" value="@Model.Email" readonly style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 4px; background-color: #f8f9fa; color: #555; box-sizing: border-box; outline: none;" />
        </div>

        <div style="margin-bottom: 25px;">
            <label style="font-weight: bold; color: #333; display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; font-size: 14px;">
                MẬT KHẨU
                <a asp-controller="Account" asp-action="ChangePassword" style="color: #c9a84c; text-decoration: none; font-size: 13px; font-weight: normal;">Thay đổi mật khẩu</a>
            </label>
            <input type="password" value="********" readonly style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 4px; background-color: #f8f9fa; color: #555; box-sizing: border-box; outline: none;" />
        </div>

        <div style="margin-bottom: 30px;">
            <label style="font-weight: bold; color: #333; display: block; margin-bottom: 8px; font-size: 14px;">SỐ ĐIỆN THOẠI</label>
            <input type="text" value="@(Model.PhoneNumber ?? "Chưa cập nhật")" readonly style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 4px; background-color: #f8f9fa; color: #999; box-sizing: border-box; outline: none; font-style: italic;" />
        </div>

        <div style="text-align: center; margin-top: 40px;">
            <a asp-controller="Account" asp-action="EditProfile" style="display: inline-block; background-color: #1a1410; color: white; padding: 14px 40px; text-decoration: none; border-radius: 4px; font-weight: bold; cursor: pointer; letter-spacing: 1px; transition: background-color 0.2s;">CHỈNH SỬA THÔNG TIN</a>
        </div>
    </div>
</div>