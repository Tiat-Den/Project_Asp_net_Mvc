@using Microsoft.AspNetCore.Identity
@model IdentityUser

@{
    ViewData["Title"] = "Chỉnh sửa thông tin";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<style>
    .profile-card {
        max-width: 600px;
        margin: 60px auto;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        overflow: hidden;
        border-top: 5px solid #c9a84c; /* Viền vàng gold */
    }

    .profile-header {
        background-color: #fdfaf6;
        padding: 40px 20px 30px;
        text-align: center;
        border-bottom: 1px solid #f0e6d2;
    }

    .avatar-circle {
        width: 100px;
        height: 100px;
        background-color: #1a1410;
        color: #c9a84c;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 35px;
        margin: 0 auto 15px;
        border: 4px solid #fff;
        box-shadow: 0 5px 15px rgba(201,168,76,0.25);
    }

    .profile-title {
        font-family: 'Cormorant Garamond', serif;
        color: #1a1410;
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .profile-subtitle {
        color: #888;
        font-size: 0.95rem;
    }

    .profile-body {
        padding: 40px;
    }

    .info-group {
        margin-bottom: 25px;
        position: relative;
    }

    .info-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #1a1410;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
        display: block;
    }

    .info-input {
        width: 100%;
        padding: 14px 15px 14px 45px;
        border: 1px solid #e5e5e5;
        border-radius: 8px;
        background-color: #fff;
        color: #1a1410;
        font-size: 1.05rem;
        transition: all 0.3s;
        outline: none;
    }

        .info-input:focus {
            border-color: #c9a84c;
            box-shadow: 0 0 0 3px rgba(201,168,76,0.15);
        }
        /* Style riêng cho các ô không được phép sửa */
        .info-input.locked {
            background-color: #f5f5f5;
            color: #888;
            cursor: not-allowed;
        }

    .info-icon {
        position: absolute;
        left: 16px;
        top: 42px;
        color: #c9a84c;
        font-size: 1.1rem;
    }

    .btn-group-custom {
        display: flex;
        gap: 15px;
        margin-top: 35px;
    }

    .btn-cancel {
        flex: 1;
        background-color: #f8f9fa;
        color: #555;
        border: 1px solid #ddd;
        padding: 14px 20px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .btn-cancel:hover {
            background-color: #e2e6ea;
            color: #1a1410;
        }

    .btn-save {
        flex: 1;
        background-color: #1a1410;
        color: #c9a84c;
        border: 1px solid #1a1410;
        padding: 14px 20px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-save:hover {
            background-color: #c9a84c;
            color: #fff;
            border-color: #c9a84c;
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(201,168,76,0.3);
        }
</style>

<div class="profile-card">
    <div class="profile-header">
        <div class="avatar-circle">
            <i class="fas fa-user-edit"></i>
        </div>
        <h2 class="profile-title">Chỉnh Sửa Thông Tin</h2>
        <div class="profile-subtitle">Cập nhật thông tin liên lạc của bạn</div>
    </div>

    <form asp-controller="Account" asp-action="EditProfile" method="post" class="profile-body">

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger" style="border-radius: 8px; font-weight: bold; margin-bottom: 20px;">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
            </div>
        }

        <div class="info-group">
            <label class="info-label">Tên Đăng Nhập</label>
            <i class="fas fa-user info-icon"></i>
            <input type="text" name="UserName" value="@Model.UserName" placeholder="Nhập tên đăng nhập mới..." class="info-input" required />
        </div>

        <div class="info-group">
            <label class="info-label">Địa Chỉ Email</label>
            <i class="fas fa-envelope info-icon"></i>
            <input type="email" name="Email" value="@Model.Email" placeholder="Nhập email mới..." class="info-input" required />
        </div>

        <div class="info-group">
            <label class="info-label">Số Điện Thoại</label>
            <i class="fas fa-phone-alt info-icon"></i>
            <input type="text" name="PhoneNumber" value="@Model.PhoneNumber" placeholder="Nhập số điện thoại của bạn..." class="info-input" />
        </div>

        <div class="btn-group-custom">
            <a asp-action="Profile" class="btn-cancel">Hủy Bỏ</a>
            <button type="submit" class="btn-save">
                <i class="fas fa-save me-2"></i> Lưu Thay Đổi
            </button>
        </div>

    </form>
</div>