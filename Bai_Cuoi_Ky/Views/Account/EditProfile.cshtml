@using Microsoft.AspNetCore.Identity
@model IdentityUser

@{
    ViewData["Title"] = "Chỉnh sửa thông tin";
}

<div style="max-width: 800px; margin: 50px auto; padding: 20px; font-family: Arial, sans-serif;">
    <h2 style="text-align: center; margin-bottom: 30px; color: #1a1410; text-transform: uppercase; letter-spacing: 2px;">CHỈNH SỬA THÔNG TIN</h2>

    <form asp-controller="Account" asp-action="EditProfile" method="post" style="background: #fff; padding: 40px; border-radius: 8px; border: 1px solid #eaeaea; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">

        <div style="margin-bottom: 25px;">
            <label style="font-weight: bold; color: #333; display: block; margin-bottom: 8px; font-size: 14px;">TÊN ĐĂNG NHẬP (Không thể đổi)</label>
            <input type="text" value="@Model.UserName" disabled style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 4px; background-color: #e9ecef; color: #555; box-sizing: border-box; outline: none;" />
        </div>

        <div style="margin-bottom: 25px;">
            <label style="font-weight: bold; color: #333; display: block; margin-bottom: 8px; font-size: 14px;">EMAIL (Không thể đổi)</label>
            <input type="email" value="@Model.Email" disabled style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 4px; background-color: #e9ecef; color: #555; box-sizing: border-box; outline: none;" />
        </div>

        <div style="margin-bottom: 30px;">
            <label style="font-weight: bold; color: #333; display: block; margin-bottom: 8px; font-size: 14px;">SỐ ĐIỆN THOẠI</label>
            <input type="text" name="PhoneNumber" value="@Model.PhoneNumber" style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 4px; background-color: #fff; color: #333; box-sizing: border-box; outline: none;" />
        </div>

        <div style="text-align: center; margin-top: 40px; display: flex; gap: 15px; justify-content: center;">
            <a asp-action="Profile" style="background-color: #ccc; color: #333; padding: 14px 40px; border-radius: 4px; font-weight: bold; text-decoration: none; letter-spacing: 1px;">HỦY BỎ</a>
            <button type="submit" style="background-color: #1a1410; color: white; padding: 14px 40px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; letter-spacing: 1px; transition: background-color 0.2s;">LƯU THAY ĐỔI</button>
        </div>
    </form>
</div>