@{
    ViewData["Title"] = "Thay đổi mật khẩu";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<style>
    .profile-card {
        max-width: 600px;
        margin: 60px auto;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        overflow: hidden;
        border-top: 5px solid #c9a84c;
    }

    .profile-header {
        background-color: #fdfaf6;
        padding: 40px 20px 30px;
        text-align: center;
        border-bottom: 1px solid #f0e6d2;
    }

    .avatar-circle {
        width: 100px;
        height: 100px;
        background-color: #1a1410;
        color: #c9a84c;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 35px;
        margin: 0 auto 15px;
        border: 4px solid #fff;
        box-shadow: 0 5px 15px rgba(201,168,76,0.25);
    }

    .profile-title {
        font-family: 'Cormorant Garamond', serif;
        color: #1a1410;
        font-size: 2.2rem;
        font-weight: 700;
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .profile-subtitle {
        color: #888;
        font-size: 0.95rem;
    }

    .profile-body {
        padding: 40px;
    }

    .info-group {
        margin-bottom: 25px;
        position: relative;
    }

    .info-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #1a1410;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
        display: block;
    }

    .input-wrapper {
        position: relative;
    }

    .info-input {
        width: 100%;
        padding: 14px 45px 14px 45px; /* Chừa chỗ cho cả 2 icon trái phải */
        border: 1px solid #e5e5e5;
        border-radius: 8px;
        background-color: #fff;
        color: #1a1410;
        font-size: 1.05rem;
        transition: all 0.3s;
        outline: none;
    }

        .info-input:focus {
            border-color: #c9a84c;
            box-shadow: 0 0 0 3px rgba(201,168,76,0.15);
        }

    .info-icon-left {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #c9a84c;
        font-size: 1.1rem;
        pointer-events: none; /* Không cho click vào icon bên trái */
    }

    .eye-icon {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #999;
        transition: color 0.2s;
        display: flex;
        align-items: center;
    }

        .eye-icon:hover {
            color: #c9a84c;
        }

    .btn-group-custom {
        display: flex;
        gap: 15px;
        margin-top: 35px;
    }

    .btn-cancel {
        flex: 1;
        background-color: #f8f9fa;
        color: #555;
        border: 1px solid #ddd;
        padding: 14px 20px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .btn-cancel:hover {
            background-color: #e2e6ea;
            color: #1a1410;
        }

    .btn-save {
        flex: 1;
        background-color: #1a1410;
        color: #c9a84c;
        border: 1px solid #1a1410;
        padding: 14px 20px;
        border-radius: 8px;
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-save:hover {
            background-color: #c9a84c;
            color: #fff;
            border-color: #c9a84c;
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(201,168,76,0.3);
        }

    .validation-alert {
        background-color: #fff3f3;
        border-left: 4px solid #dc3545;
        padding: 15px;
        margin-bottom: 25px;
        border-radius: 4px;
        font-size: 0.9rem;
        color: #dc3545;
    }

        .validation-alert ul {
            margin-bottom: 0;
            padding-left: 20px;
        }
</style>

<div class="profile-card">
    <div class="profile-header">
        <div class="avatar-circle">
            <i class="fas fa-key"></i>
        </div>
        <h2 class="profile-title">Thay Đổi Mật Khẩu</h2>
        <div class="profile-subtitle">Bảo mật tài khoản của bạn bằng một mật khẩu mạnh</div>
    </div>

    <form asp-controller="Account" asp-action="ChangePassword" method="post" class="profile-body">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-alert">
                <i class="fas fa-exclamation-circle me-2"></i><strong>Lỗi:</strong>
                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
            </div>
        }

        <div class="info-group">
            <label class="info-label">Mật Khẩu Hiện Tại</label>
            <div class="input-wrapper">
                <i class="fas fa-lock info-icon-left"></i>
                <input type="password" id="oldPwd" name="OldPassword" required class="info-input" placeholder="Nhập mật khẩu cũ..." />
                <span class="eye-icon" onclick="togglePassword('oldPwd', this)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </span>
            </div>
        </div>

        <div class="info-group">
            <label class="info-label">Mật Khẩu Mới</label>
            <div class="input-wrapper">
                <i class="fas fa-shield-alt info-icon-left"></i>
                <input type="password" id="newPwd" name="NewPassword" required class="info-input" placeholder="Nhập ít nhất 6 ký tự..." />
                <span class="eye-icon" onclick="togglePassword('newPwd', this)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </span>
            </div>
        </div>

        <div class="info-group">
            <label class="info-label">Xác Nhận Mật Khẩu Mới</label>
            <div class="input-wrapper">
                <i class="fas fa-check-circle info-icon-left"></i>
                <input type="password" id="confirmPwd" name="ConfirmPassword" required class="info-input" placeholder="Nhập lại mật khẩu mới..." />
                <span class="eye-icon" onclick="togglePassword('confirmPwd', this)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                        <circle cx="12" cy="12" r="3"></circle>
                    </svg>
                </span>
            </div>
        </div>

        <div class="btn-group-custom">
            <a asp-action="Profile" class="btn-cancel">Hủy Bỏ</a>
            <button type="submit" class="btn-save">
                <i class="fas fa-key me-2"></i> Đổi Mật Khẩu
            </button>
        </div>
    </form>
</div>

<script>
    function togglePassword(inputId, iconSpan) {
        var input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
            iconSpan.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
        } else {
            input.type = "password";
            iconSpan.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
        }
    }
</script>