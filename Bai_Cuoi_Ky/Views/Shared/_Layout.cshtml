<!DOCTYPE html>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Li Li Jewelry</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Bai_Cuoi_Ky.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

   
    <!-- HEADER -->
    <header class="site-header">
        <div class="header-inner">
            <a href="/" class="logo">
                <div>
                    <span class="logo-name">DKH</span>
                    <span class="logo-sub">Premium Jewelry</span>
                </div>
            </a>

            <div class="search-bar">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" placeholder="Tìm kiếm sản phẩm..." />
                
            </div>

            <div class="header-actions">
                @if (SignInManager.IsSignedIn(User))
                {
                    @if (User.IsInRole("Admin") || User.IsInRole("NhanVien"))
                    {
                        <a class="nav-link text-danger font-weight-bold" href="/Admin/Index">TRANG QUẢN TRỊ</a>
                    }
                    var currentUser = await UserManager.GetUserAsync(User);

                    <div class="user-menu-container">
                        <a href="javascript:void(0);" class="header-btn" style="color:#000000 !important;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                            @currentUser?.Email
                        </a>

                        <div class="user-dropdown">
                            <a asp-controller="Account" asp-action="Profile">Thông tin tài khoản</a>
                            <a href="#">Đơn hàng của tôi</a>
                            <a href="#">Sản phẩm yêu thích</a>
                            <a asp-controller="Account" asp-action="Logout" style="border-top: 1px solid #eee; color: red;">Đăng xuất</a>
                        </div>
                    </div>
                }

                else

                {
                    <div style="display: flex; gap: 10px;">
                        <a href="javascript:void(0);" onclick="openAuthModal('register')" class="header-btn" style="color:#000000 !important;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                            Đăng Ký
                        </a>

                        <a href="javascript:void(0);" onclick="openAuthModal('login')" class="header-btn" style="color:#000000 !important;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                                <polyline points="10 17 15 12 10 7"></polyline>
                                <line x1="15" y1="12" x2="3" y2="12"></line>
                            </svg>
                            Đăng Nhập
                        </a>
                    </div>
                }
                <a href="#" class="header-btn dark-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="#1a1410" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                    <span style="color:#000000;">0</span>
                </a>
            </div>
        </div>
    </header>

    <!-- NAVBAR DANH MỤC -->
    <nav class="main-nav">
        <div class="nav-inner">
            <a asp-controller="Product" asp-action="Index" class="nav-link-item">Tất Cả</a>
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="1" class="nav-link-item">Vòng - Lắc</a>
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="2" class="nav-link-item">Nhẫn</a>
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="3" class="nav-link-item">Dây Chuyền</a>
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="4" class="nav-link-item">Bông Tai</a>
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="5" class="nav-link-item">Trang Sức Đôi</a>
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="6" class="nav-link-item">Trang Sức Bộ</a>
            <a asp-controller="Product" asp-action="Index" asp-route-categoryId="7" class="nav-link-item">Phụ Kiện</a>
        </div>
    </nav>

    <!-- NỘI DUNG TRANG -->
    
        <main role="main">
            @RenderBody()
        </main>
    

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="footer-grid">
            <!-- Cột 1: Brand -->
            <div class="footer-brand">
                <div class="footer-brand-name">DKH</div>
                <div class="footer-brand-sub">Premium Jewelry</div>
                <p>Thương hiệu trang sức bạc cao cấp hàng đầu Việt Nam. Mỗi sản phẩm là một tác phẩm nghệ thuật tinh tế.</p>
            </div>

            <!-- Cột 2: Danh Mục -->
            <div class="footer-col">
                <h4>Danh Mục</h4>
                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="1">Vòng - Lắc</a>
                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="2">Nhẫn</a>
                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="3">Dây Chuyền</a>
                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="4">Bông Tai</a>
                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="5">Trang Sức Đôi</a>
                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="6">Trang Sức Bộ</a>
                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="7">Phụ Kiện</a>
            </div>

            <!-- Cột 3: Hỗ Trợ -->
            <div class="footer-col">
                <h4>Hỗ Trợ</h4>
                <a href="#">Chính sách đổi trả</a>
                <a href="#">Hướng dẫn chọn size</a>
                <a href="#">Bảo hành sản phẩm</a>
                <a href="#">Liên hệ</a>
            </div>

            <!-- Cột 4: Theo Dõi -->
            <div class="footer-col">
                <h4>Theo Dõi</h4>
                <a href="#">Facebook</a>
                <a href="#">Instagram</a>
                <a href="#">TikTok</a>              
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- CHAT BOX-->
    <button id="ai-chat-btn" onclick="toggleChat()">
        💬 Chat
    </button>

    <div id="ai-chat-box" class="chat-hidden">
        <div class="chat-header">
            <strong>Trợ lý AI - DKH Jewelry</strong>
            <span class="close-chat" onclick="toggleChat()">✖</span>
        </div>
        <div class="chat-messages" id="chat-messages">
            <div class="msg bot-msg">Xin chào! Tôi là trợ lý AI của DKH. Tôi có thể giúp gì cho bạn hôm nay?</div>
        </div>
        <div class="chat-input-area">
            <input type="text" id="chat-input" placeholder="Nhập tin nhắn..." onkeypress="handleEnter(event)" />
            <button onclick="sendMessage()">Gửi</button>
        </div>
    </div>

    <!-- popup đăng nhập, đăng ký -->
    <div id="auth-modal" class="auth-modal-overlay">
        <div class="auth-modal-box">
            <span class="auth-close-btn" onclick="closeAuthModal()">&times;</span>

            <div class="auth-tabs">
                <button id="btn-tab-login" class="auth-tab-btn active" onclick="switchAuthTab('login')">ĐĂNG NHẬP</button>
                <button id="btn-tab-register" class="auth-tab-btn" onclick="switchAuthTab('register')">ĐĂNG KÝ</button>
            </div>

            <form id="form-login" class="auth-form active-form" asp-controller="Account" asp-action="Login" method="post">
                <div id="login-summary" style="color:red; font-size: 0.8rem; margin-bottom: 10px;"></div>
                <div class="form-group">
                    <input type="text" name="Username" class="auth-input" placeholder="Tên đăng nhập hoặc Email" required />
                </div>
                <div class="form-group" style="position: relative;">
                    <input type="password" id="loginPassword" name="Password" class="auth-input" placeholder="Mật khẩu" required />
                    <span onclick="toggleAuthPassword('loginPassword', this)" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #999;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    </span>
                </div>
                <div class="auth-options">
                    <label><input type="checkbox" name="RememberMe" /> Nhớ mật khẩu</label>
                    <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-pw">Quên mật khẩu?</a>
                </div>
                <button type="submit" class="auth-submit-btn">ĐĂNG NHẬP</button>
                <div style="text-align:center; margin-top: 15px;">
                    <p style="font-size: 0.85rem; color: #888;">Hoặc đăng nhập bằng</p>
                    <div style="display: flex; gap: 10px; justify-content: center; margin-top: 10px;">
                        <a asp-controller="Account" asp-action="ExternalLogin" asp-route-provider="Google" class="btn-google">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" alt="Google" class="google-icon" />
                            Google
                        </a>
                    </div>
                </div>
            </form>

            <form id="form-register" class="auth-form" asp-controller="Account" asp-action="Register" method="post">
                <div id="register-summary" style="color:red; font-size: 0.8rem; margin-bottom: 10px;"></div>
                <div class="form-group">
                    <input type="text" name="Email" class="auth-input" placeholder="Email" required />
                </div>
                <div class="form-group">
                    <input type="text" name="Username" class="auth-input" placeholder="Tên đăng nhập" required />
                </div>
                <div class="form-group" style="position: relative;">
                    <input type="password" id="regPassword" name="Password" class="auth-input" placeholder="Mật khẩu" required />
                    <span onclick="toggleAuthPassword('regPassword', this)" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #999;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    </span>
                </div>
                <div class="form-group" style="position: relative;">
                    <input type="password" id="regConfirmPassword" name="ConfirmPassword" class="auth-input" placeholder="Nhập lại mật khẩu" required />
                    <span onclick="toggleAuthPassword('regConfirmPassword', this)" style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #999;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    </span>
                </div>
                <button type="submit" class="auth-submit-btn">TẠO TÀI KHOẢN</button>
            </form>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            // XỬ LÝ ĐĂNG NHẬP
            $("#form-login").on("submit", function (e) {
                e.preventDefault(); // Chặn tuyệt đối việc load lại trang

                var form = $(this);
                var summary = $("#login-summary");
                summary.text("Đang kiểm tra..."); // Hiển thị trạng thái chờ

                $.post(form.attr("action"), form.serialize())
                    .done(function (response) {
                        // Nếu đúng, mới cho chuyển trang
                        window.location.href = "/Home/Index";
                    })
                    .fail(function (xhr) {
                        // Nếu sai, ở lại trang và hiện lỗi vào div
                        summary.text(xhr.responseText || "Sai tài khoản hoặc mật khẩu!");
                    });

                return false; // Thêm dòng này để chắc chắn không nhảy trang
            });

            // XỬ LÝ ĐĂNG KÝ
            $("#form-register").on("submit", function (e) {
                e.preventDefault();

                var form = $(this);
                var summary = $("#register-summary");

                $.post(form.attr("action"), form.serialize())
                    .done(function (response) {
                        alert("Đăng ký thành công!");
                        window.location.reload();
                    })
                    .fail(function (xhr) {
                        summary.text(xhr.responseText || "Lỗi đăng ký, vui lòng thử lại!");
                    });

                return false;
            });
        });

        // Hàm con mắt mật khẩu (giữ nguyên cái này)
        function toggleAuthPassword(inputId, iconSpan) {
            var input = document.getElementById(inputId);
            if (input.type === "password") {
                input.type = "text";
                iconSpan.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>';
            } else {
                input.type = "password";
                iconSpan.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>';
            }
        }
    </script>

    <script>
        // ===== CHAT BOX =====
        function toggleChat() {
            const chatBox = document.getElementById('ai-chat-box');
            if (chatBox.classList.contains('chat-hidden')) {
                chatBox.classList.remove('chat-hidden');
                chatBox.classList.add('chat-active');
            } else {
                chatBox.classList.remove('chat-active');
                chatBox.classList.add('chat-hidden');
            }
        }

        function handleEnter(e) {
            if (e.key === 'Enter') sendMessage();
        }

        async function sendMessage() {
            const input = document.getElementById('chat-input');
            const message = input.value.trim();
            if (!message) return;

            const chatMessages = document.getElementById('chat-messages');

            chatMessages.innerHTML += `<div class="msg user-msg">${message}</div>`;
            input.value = '';
            chatMessages.scrollTop = chatMessages.scrollHeight;

            const typingId = 'typing-' + Date.now();
            chatMessages.innerHTML += `<div id="${typingId}" class="msg typing">...</div>`;
            chatMessages.scrollTop = chatMessages.scrollHeight;

            try {
                const response = await fetch('/Home/GetAiResponse', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: message })
                });

                const data = await response.json();

                document.getElementById(typingId).remove();
                chatMessages.innerHTML += `<div class="msg bot-msg">${data.reply}</div>`;
                chatMessages.scrollTop = chatMessages.scrollHeight;

            } catch (error) {
                document.getElementById(typingId).remove();
                chatMessages.innerHTML += `<div class="msg bot-msg" style="color:red;">Lỗi kết nối đến AI!</div>`;
            }
        }

        // ===== ĐĂNG NHẬP / ĐĂNG KÝ POPUP =====
        function openAuthModal(tab) {
            document.getElementById('auth-modal').classList.add('show');
            switchAuthTab(tab);
        }

        function closeAuthModal() {
            document.getElementById('auth-modal').classList.remove('show');
        }

        function switchAuthTab(tab) {
            document.getElementById('btn-tab-login').classList.remove('active');
            document.getElementById('btn-tab-register').classList.remove('active');
            document.getElementById('form-login').classList.remove('active-form');
            document.getElementById('form-register').classList.remove('active-form');

            if (tab === 'login') {
                document.getElementById('btn-tab-login').classList.add('active');
                document.getElementById('form-login').classList.add('active-form');
            } else {
                document.getElementById('btn-tab-register').classList.add('active');
                document.getElementById('form-register').classList.add('active-form');
            }
        }

        // Đóng popup khi click ra ngoài vùng xám
        window.onclick = function (event) {
            const modal = document.getElementById('auth-modal');
            if (event.target == modal) {
                closeAuthModal();
            }
        }
    </script>
</body>
</html>
