<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Li Li Jewelry</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Bai_Cuoi_Ky.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />
    @await RenderSectionAsync("Styles", required: false)

    <style>
        * {
            box-sizing: border-box;
        }

        :root {
            --red: #c0392b;
            --red-dark: #962d22;
            --gold: #c9a84c;
            --dark: #1a1410;
            --muted: #888;
            --border: #e8e8e8;
        }

        body {
            font-family: 'Jost', sans-serif;
            margin: 0;
            padding: 0;
        }

        /* Ẩn navbar & footer mặc định Bootstrap */
        .navbar {
            display: none !important;
        }

        footer.border-top {
            display: none !important;
        }

        .container > main {
            padding: 0 !important;
        }

        .container {
            max-width: 100% !important;
            padding: 0 !important;
        }

        /* ===== TOP BAR ===== */
        .top-bar {
            background: var(--red);
            color: white;
            text-align: center;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            padding: 7px 0;
            font-weight: 500;
        }

        /* ===== HEADER ===== */
        .site-header {
            background: white;
            border-bottom: 1px solid var(--border);
            padding: 0 40px;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }

        .header-inner {
            display: flex;
            align-items: center;
            gap: 32px;
            height: 70px;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* Logo */
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            flex-shrink: 0;
        }

        .logo-icon {
            width: 48px;
            height: 48px;
            background: var(--red);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.3rem;
            font-weight: 700;
            font-family: 'Cormorant Garamond', serif;
        }

        .logo-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.6rem;
            font-weight: 600;
            color: var(--red);
            letter-spacing: 1px;
            line-height: 1.1;
            display: block;
        }

        .logo-sub {
            font-size: 0.56rem;
            letter-spacing: 3px;
            color: var(--red);
            text-transform: uppercase;
            display: block;
        }

        /* Search */
        .search-bar {
            flex: 1;
            max-width: 580px;
            display: flex;
            border-bottom: 2px solid var(--dark);
            align-items: center;
            gap: 8px;
            padding-bottom: 4px;
        }

            .search-bar input {
                flex: 1;
                border: none;
                outline: none;
                font-family: 'Jost', sans-serif;
                font-size: 0.88rem;
                color: var(--dark);
                background: transparent;
            }

                .search-bar input::placeholder {
                    color: #bbb;
                }

            .search-bar button {
                background: none;
                border: none;
                cursor: pointer;
                color: var(--dark);
                font-size: 1rem;
            }

        /* Header Actions */
        .header-actions {
            display: flex;
            gap: 10px;
            margin-left: auto;
        }

        .header-btn {
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 8px 16px;
            border: 1.5px solid var(--dark);
            background: white;
            font-family: 'Jost', sans-serif;
            font-size: 0.76rem;
            color: var(--dark);
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
            white-space: nowrap;
        }

            .header-btn:hover {
                background: white;
                color: var(--dark);
                text-decoration: none;
            }
        .cart-btn {
            background: var(--red);
            border-color: var(--red);
            color: white;
        }


        .cart-badge {
            background: var(--gold);
            color: white;
            border-radius: 50%;
            width: 18px;
            height: 18px;
            font-size: 0.62rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
        }

        /* ===== NAVBAR ===== */
        .main-nav {
            background: white;
            border-bottom: 2px solid var(--border);
        }

        .nav-inner {
            display: flex;
            justify-content: center;
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 40px;
            overflow-x: auto;
        }

        .nav-link-item {
            padding: 14px 16px;
            font-size: 0.75rem;
            letter-spacing: 1.2px;
            font-weight: 500;
            text-transform: uppercase;
            color: var(--dark) !important;
            text-decoration: none !important;
            position: relative;
            transition: color 0.2s;
            white-space: nowrap;
        }

            .nav-link-item::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 0;
                height: 2px;
                background: var(--red);
                transition: width 0.25s;
            }

            .nav-link-item:hover {
                color: var(--red) !important;
            }

                .nav-link-item:hover::after {
                    width: 80%;
                }

            .nav-link-item.highlight {
                color: var(--red) !important;
            }

        /* ===== FOOTER ===== */
        .site-footer {
            background: #000000;
            color: rgba(255,255,255,0.7);
            padding: 48px 40px 24px;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr; /* giữ nguyên */
            gap: 40px;
            max-width: 1400px;
            margin: 0 auto 40px;
            align-items: start;
        }

        .footer-brand-name {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.8rem;
            color: white;
            font-weight: 600;
        }

        .footer-brand-sub {
            font-size: 0.56rem;
            letter-spacing: 3px;
            color: rgba(255,255,255,0.4);
            text-transform: uppercase;
        }

        .footer-brand p {
            font-size: 0.82rem;
            line-height: 1.7;
            margin-top: 12px;
        }

        .footer-col h4 {
            font-size: 0.7rem;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: white;
            margin-bottom: 16px;
            font-weight: 500;
        }

        .footer-col a {
            display: block;
            color: rgba(255,255,255,0.6);
            font-size: 0.82rem;
            text-decoration: none;
            margin-bottom: 8px;
            transition: color 0.2s;
        }

            .footer-col a:hover {
                color: var(--gold);
            }

        .footer-bottom {
            max-width: 1400px;
            margin: 0 auto;
            padding-top: 24px;
            border-top: 1px solid rgba(255,255,255,0.1);
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
        }
    </style>
</head>
<body>

   
    <!-- HEADER -->
    <header class="site-header">
        <div class="header-inner">
            <a href="/" class="logo">
                <div>
                    <span class="logo-name">DKH</span>
                    <span class="logo-sub">Premium Jewelry</span>
                </div>
            </a>

            <div class="search-bar">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" placeholder="Tìm kiếm sản phẩm..." />
                
            </div>

            <div class="header-actions">
                <a href="#" class="header-btn" style="color:#000000 !important;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    Đăng Ký
                </a>

                <a href="#" class="header-btn" style="color:#000000 !important;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
                        <polyline points="10 17 15 12 10 7"></polyline>
                        <line x1="15" y1="12" x2="3" y2="12"></line>
                    </svg>
                    Đăng Nhập
                </a>
                <a href="#" class="header-btn dark-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="#1a1410" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                    <span style="color:#000000;">0</span>
                </a>
            </div>
        </div>
    </header>

    <!-- NAVBAR DANH MỤC -->
    <nav class="main-nav">
        <div class="nav-inner">
            <a href="@Url.Action("Index", "Product", new { category = "Vòng - Lắc" })" class="nav-link-item">Vòng - Lắc</a>
            <a href="@Url.Action("Index", "Product", new { category = "Nhẫn" })" class="nav-link-item">Nhẫn</a>
            <a href="@Url.Action("Index", "Product", new { category = "Dây Chuyền" })" class="nav-link-item">Dây Chuyền</a>
            <a href="@Url.Action("Index", "Product", new { category = "Bông Tai" })" class="nav-link-item">Bông Tai</a>
            <a href="@Url.Action("Index", "Product", new { category = "Trang Sức Đôi" })" class="nav-link-item">Trang Sức Đôi</a>
            <a href="@Url.Action("Index", "Product", new { category = "Trang Sức Bộ" })" class="nav-link-item">Trang Sức Bộ</a>
            <a href="@Url.Action("Index", "Product", new { category = "Phụ Kiện" })" class="nav-link-item">Phụ Kiện</a>
        </div>
    </nav>

    <!-- NỘI DUNG TRANG -->
    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="footer-grid">
            <!-- Cột 1: Brand -->
            <div class="footer-brand">
                <div class="footer-brand-name">DKH</div>
                <div class="footer-brand-sub">Premium Jewelry</div>
                <p>Thương hiệu trang sức bạc cao cấp hàng đầu Việt Nam. Mỗi sản phẩm là một tác phẩm nghệ thuật tinh tế.</p>
            </div>

            <!-- Cột 2: Danh Mục -->
            <div class="footer-col">
                <h4>Danh Mục</h4>
                <a href="@Url.Action("Index", "Product", new { category = "Vòng - Lắc" })">Vòng - Lắc</a>
                <a href="@Url.Action("Index", "Product", new { category = "Nhẫn" })">Nhẫn</a>
                <a href="@Url.Action("Index", "Product", new { category = "Dây Chuyền" })">Dây Chuyền</a>
                <a href="@Url.Action("Index", "Product", new { category = "Bông Tai" })">Bông Tai</a>
                <a href="@Url.Action("Index", "Product", new { category = "Trang Sức Đôi" })">Trang Sức Đôi</a>
                <a href="@Url.Action("Index", "Product", new { category = "Trang Sức Bộ" })">Trang Sức Bộ</a>
                <a href="@Url.Action("Index", "Product", new { category = "Phụ Kiện" })">Phụ Kiện</a>
            </div>

            <!-- Cột 3: Hỗ Trợ -->
            <div class="footer-col">
                <h4>Hỗ Trợ</h4>
                <a href="#">Chính sách đổi trả</a>
                <a href="#">Hướng dẫn chọn size</a>
                <a href="#">Bảo hành sản phẩm</a>
                <a href="#">Liên hệ</a>
            </div>

            <!-- Cột 4: Theo Dõi -->
            <div class="footer-col">
                <h4>Theo Dõi</h4>
                <a href="#">Facebook</a>
                <a href="#">Instagram</a>
                <a href="#">TikTok</a>              
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>



