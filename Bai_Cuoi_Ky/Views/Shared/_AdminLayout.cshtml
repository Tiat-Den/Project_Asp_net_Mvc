<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bảng Điều Khiển Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&display=swap" rel="stylesheet" />   
    <style>
        body, .card, .card *:not(i):not(.fas):not(.far):not(.fab) {
            font-family: 'Cormorant Garamond', serif !important;
        }
        body {
            background-color: #f4f6f9;
            overflow-x: hidden; /* Ngăn scroll ngang khi trượt panel */
        }

        /* Tùy chỉnh thanh Sidebar */
        .sidebar {
            min-height: 100vh;
            background-color: #343a40;
            color: white;
            width: 260px; /* Cố định chiều rộng thay vì dùng col-2 */
            min-width: 260px;
            transition: all 0.3s ease-in-out; /* Hiệu ứng trượt mượt mà */
            white-space: nowrap; /* Tránh chữ bị rớt dòng khi thu nhỏ */
            overflow-x: hidden;
            z-index: 1000;
        }

            /* Class để ẩn sidebar */
            .sidebar.collapsed {
                width: 0;
                min-width: 0;
            }

            .sidebar a {
                color: #c2c7d0;
                text-decoration: none;
                padding: 12px 20px;
                display: block;
                font-size: 1.05rem;
                transition: all 0.2s;
            }

                .sidebar a:hover, .sidebar a.active {
                    background-color: #007bff;
                    color: white;
                    border-left: 4px solid #ffffff;
                    padding-left: 16px;
                }

        /* Khu vực nội dung chính */
        .main-content {
            padding: 18px;
            flex-grow: 1; /* Chiếm toàn bộ không gian còn lại */
            width: 100%;
            transition: all 0.3s ease-in-out;
        }

        /* Ô vuông nút ẩn/hiện Panel */
        .toggle-btn {
            width: 40px;
            height: 40px;
            background-color: #343a40;
            color: #fff;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.2s;
        }

            .toggle-btn:hover {
                background-color: #007bff;
            }
            /*PHÂN TRANG*/

        .pagination-container {
            display: flex;
            justify-content: center; /* Ép ra giữa màn hình */
            align-items: center;
            margin-top: 50px;
            margin-bottom: 50px;
            width: 100%;
        }

        .pagination {
            display: flex;
            list-style: none;
            padding: 0;
            margin: 0;
            gap: 12px; /* Khoảng cách giữa các nút */
        }

            .pagination .page-item {
                margin: 0;
            }

            .pagination .page-link {
                display: flex;
                align-items: center;
                justify-content: center;
                min-width: 45px;
                height: 45px;
                padding: 0 16px;
                color: #1a1410;
                background-color: #ffffff;
                border: 1px solid #e5e5e5;
                text-decoration: none;
                font-family: 'Cormorant Garamond', serif; /* Font chữ sang trọng của web ông */
                font-size: 1.2rem;
                font-weight: 600;
                border-radius: 8px; /* Bo góc mềm mại */
                transition: all 0.3s ease;
            }

                /* Hiệu ứng khi rê chuột vào (Hover) */
                .pagination .page-link:hover {
                    background-color: #fdfaf6;
                    border-color: #c9a84c;
                    color: #c9a84c;
                    transform: translateY(-3px); /* Nhảy nhẹ lên một chút */
                    box-shadow: 0 5px 15px rgba(201, 168, 76, 0.2); /* Đổ bóng màu vàng gold */
                }

            /* Nút của trang hiện tại (Active) */
            .pagination .page-item.active .page-link {
                background-color: #c9a84c;
                border-color: #c9a84c;
                color: #ffffff;
                cursor: default;
                transform: none;
                box-shadow: 0 4px 10px rgba(201, 168, 76, 0.4);
            }
    </style>
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <div class="d-flex w-100">

        <div class="sidebar flex-column p-0" id="adminSidebar">
            @if (User.IsInRole("Admin"))
            {
                <h4 class="text-center py-4 border-bottom border-secondary fw-bold mb-0">ADMIN PANEL</h4>
            }
            else
            {
                <h4 class="text-center py-4 border-bottom border-secondary fw-bold mb-0">NHÂN VIÊN PANEL</h4>
            }

            <a href="/Admin/Index" class="@(currentController == "Admin" && currentAction == "Index" ? "active" : "")">
                <i class="fas fa-tachometer-alt me-2"></i> Tổng quan
            </a>

            <a href="/Product/IndexAdmin" class="@(currentController == "Product" ? "active" : "")">
                <i class="fas fa-box me-2"></i> Quản lý sản phẩm
            </a>

            <a href="/Category/Index" class="@(currentController == "Category" ? "active" : "")">
                <i class="fas fa-list me-2"></i> Quản lý danh mục
            </a>

            <a href="/Order/Index" class="@(currentController == "Order" ? "active" : "")">
                <i class="fas fa-shopping-cart me-2"></i> Quản lý đơn hàng
            </a>

            @if (User.IsInRole("Admin"))
            {
                <a href="/RoleManager/Users" class="@(currentController == "RoleManager" && currentAction == "Users" ? "active" : "")">
                    <i class="fas fa-users me-2"></i> Quản lý người dùng
                </a>

                <a href="/RoleManager/Index" class="@(currentController == "RoleManager" && currentAction == "Index" ? "active" : "")">
                    <i class="fas fa-user-shield me-2"></i> Quản lý phân quyền
                </a>
            }

            <hr class="border-secondary my-3" />

            <a href="/Home/Index" class="text-warning">
                <i class="fas fa-home me-2"></i> Về trang khách
            </a>
            <a href="/Account/Logout" class="text-danger">
                <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất
            </a>
        </div>
        <button type="button" id="sidebarToggle" class="toggle-btn me-3">
            <i class="fas fa-bars"></i>
        </button>

        <div class="main-content">
            <nav class="navbar navbar-light bg-white shadow-sm mb-4 rounded px-3 py-2 d-flex align-items-center justify-content-start">

                

                @if (User.IsInRole("Admin"))
                {
                    <span class="navbar-brand mb-0 h5 fw-bold text-primary">Xin chào, Quản trị viên!</span>
                }
                else
                {
                    <span class="navbar-brand mb-0 h5 fw-bold text-primary">Xin chào, @User.Identity.Name</span>
                }
            </nav>

            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
            $("#sidebarToggle").click(function () {
                $("#adminSidebar").toggleClass("collapsed");
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>