@model List<Bai_Cuoi_Ky.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .container *:not(i):not(.fas):not(.far):not(.fab) {
        font-family: 'Cormorant Garamond', serif !important;
    }
    /* Icon giỏ hàng màu đen */
    .fa-shopping-cart {
        color: #1a1410 !important;
    }

    /* Nút "Quay lại cửa hàng" và "Thanh toán" màu đen */
    .btn-primary, .btn-success, .btn-outline-secondary {
        background-color: #1a1410 !important;
        border-color: #1a1410 !important;
        color: white !important;
    }

        .btn-primary:hover, .btn-success:hover, .btn-outline-secondary:hover {
            background-color: #c9a84c !important;
            border-color: #c9a84c !important;
            color: white !important;
        }
</style>

<div class="container mt-5 mb-5">
    <h3 class="fw-bold mb-4 text-center">Giỏ hàng của bạn</h3>
    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive shadow-sm">
            <table class="table table-bordered align-middle text-center bg-white mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="py-3">Sản phẩm</th>
                        <th class="py-3">Đơn giá</th>
                        <th class="py-3" style="width: 160px;">Số lượng</th>
                        <th class="py-3">Thành tiền</th>
                        <th class="py-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-start">
                                <div class="d-flex align-items-center">
                                    <img src="@item.ImageUrl" alt="@item.ProductName" style="width: 70px; height: 70px; object-fit: cover;" class="rounded me-3 border" onerror="this.src='https://via.placeholder.com/70'" />
                                    <span class="fw-bold" style="font-size: 1.1rem;">@item.ProductName</span>
                                </div>
                            </td>
                            <td class="text-danger fw-bold">@item.Price.ToString("N0")đ</td>
                            <td>
                                <div class="input-group input-group-sm justify-content-center">
                                    <a href="/Cart/UpdateQuantity?id=@item.ProductId&amount=-1" class="btn btn-outline-secondary px-3">-</a>
                                    <input type="text" value="@item.Quantity" class="form-control text-center" style="max-width: 50px;" readonly />
                                    <a href="/Cart/UpdateQuantity?id=@item.ProductId&amount=1" class="btn btn-outline-secondary px-3">+</a>
                                </div>
                            </td>
                            <td class="text-danger fw-bold">@item.Total.ToString("N0")đ</td>
                            <td>
                                <a href="/Cart/Remove/@item.ProductId" class="btn btn-outline-danger btn-sm">
                                    <i class="fas fa-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-4 bg-white p-4 shadow-sm rounded">
            <a href="/" class="btn btn-outline-secondary fw-bold">
                <i class="fas fa-arrow-left me-2"></i> Tiếp tục mua sắm
            </a>
            <div class="text-end">
                <h4 class="mb-3">Tổng thanh toán: <span class="text-danger fw-bold fs-3 ms-2">@Model.Sum(x => x.Total).ToString("N0")đ</span></h4>

                @if (User.Identity.IsAuthenticated)
                {
                    <a href="/Checkout/Index" class="btn btn-success btn-lg fw-bold px-5">
                        Thanh toán ngay <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                }
                else
                {
                    <button type="button" class="btn btn-success btn-lg fw-bold px-5" onclick="triggerHeaderLogin()">
                        Thanh toán ngay <i class="fas fa-arrow-right ms-2"></i>
                    </button>
                }
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white shadow-sm rounded">
            <i class="fas fa-cart-arrow-down fa-5x text-muted mb-4"></i>
            <h4 class="text-muted mb-4">Giỏ hàng của bạn đang trống</h4>
            <a href="/" class="btn btn-primary btn-lg fw-bold px-5">Quay lại cửa hàng</a>
        </div>
    }
</div>

<script>
        function triggerHeaderLogin() {
        // 1. Tìm ô input ẩn trong form đăng nhập (thường nằm trong _Layout)
        var hiddenReturnUrl = document.querySelector('#form-login input[name="ReturnUrl"]');

        if (hiddenReturnUrl) {
            // Gán trang đích là Checkout để sau khi login Ajax xong nó biết đường mà đi
            hiddenReturnUrl.value = "/Checkout/Index";
        }

        var loginBtn = document.getElementById("btnLoginHeader");

        if (loginBtn) {
            // 2. Nếu nút này là nút mở Modal (có data-bs-toggle), nó sẽ mở modal
            // Nếu nút này là link chuyển trang, nó sẽ chuyển sang /Account/Login
            loginBtn.click();
        } else {
            window.location.href = "/Account/Login?ReturnUrl=/Checkout/Index";
        }
    }
</script>