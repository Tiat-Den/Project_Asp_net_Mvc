@{
    ViewData["Title"] = "Tổng quan";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary h-100 border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title" style="font-size: 1.1rem;">Tổng Doanh Thu</h5>
                <h3 class="card-text fw-bold">@ViewBag.TotalRevenue VNĐ</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-success h-100 border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title" style="font-size: 1.1rem;">Tổng đơn hàng</h5>
                <h3 class="card-text fw-bold">@ViewBag.TotalOrder</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-warning h-100 border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title" style="font-size: 1.1rem;">Tổng Sản Phẩm</h5>
                <h3 class="card-text fw-bold">@ViewBag.TotalProducts</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-danger h-100 border-0 shadow-sm">
            <div class="card-body">
                <h5 class="card-title" style="font-size: 1.1rem;">Khách Hàng</h5>
                <h3 class="card-text fw-bold">@ViewBag.TotalCustomers</h3>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom">
        <h5 class="mb-0 py-2" style="font-size: 1.1rem;">Đơn hàng chờ xử lý</h5>
    </div>
    <div class="card-body">
        @if (ViewBag.PendingOrdersCount != null && ViewBag.PendingOrdersCount > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover table-bordered mt-3 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center">Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th class="text-end">Tổng tiền</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in ViewBag.PendingOrders)
                        {
                            <tr>
                                <td class="text-center fw-bold">#@order.Id</td>
                                <td>@order.CustomerName</td>
                                <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end text-danger fw-bold">@order.TotalAmount.ToString("N0") VNĐ</td>
                                <td class="text-center">
                                    <span class="badge bg-warning text-dark">Chờ xử lý</span>
                                </td>
                                <td class="text-center">
                                    <a href="/Order/Details/@order.Id" class="btn btn-sm btn-info text-white">
                                        <i class="fas fa-eye"></i> Xem
                                    </a>
                                    <a href="/Order/Approve/@order.Id" class="btn btn-sm btn-success">
                                        <i class="fas fa-check"></i> Duyệt
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-secondary mb-0 text-center py-4">Chưa có đơn hàng nào cần xử lý hôm nay.</p>
        }
    </div>
</div>