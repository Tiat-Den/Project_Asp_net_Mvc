@model Bai_Cuoi_Ky.Models.Product
@{
    ViewData["Title"] = "Chỉnh Sửa: " + Model.Name;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Cormorant Garamond:wght@300;400;500&display=swap" rel="stylesheet" />

<link rel="stylesheet" href="~/css/product_Css/form.css" />

<div class="form-header">
    <h1>Chỉnh Sửa Sản Phẩm</h1>
    <p>Cập nhật thông tin chi tiết cho sản phẩm bên dưới</p>
</div>

<div class="container">
    <div class="form-card">
        <div style="display: inline-block; background: #f5f0e8; color: #8a7968; padding: 4px 12px; font-size: 0.72rem; letter-spacing: 1px; margin-bottom: 24px;">
            PRODUCT ID: #@Model.Id
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="form-section-title">Thông Tin Cơ Bản</div>

            <div class="form-group">
                <label asp-for="Name">Tên sản phẩm *</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="CategoryId">Danh mục *</label>
                    <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Material">Chất liệu</label>
                    <input asp-for="Material" class="form-control" />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Description">Mô tả</label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <hr class="form-divider" />
            <div class="form-section-title">Giá & Tồn Kho</div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Price">Giá bán (₫) *</label>
                    <input asp-for="Price" type="number" class="form-control" min="0" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="DiscountPrice">Giá gốc / Giảm giá (₫)</label>
                    <input asp-for="DiscountPrice" type="number" class="form-control" min="0" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Stock">Số lượng tồn kho *</label>
                    <input asp-for="Stock" type="number" class="form-control" min="0" />
                    <span asp-validation-for="Stock" class="text-danger"></span>
                </div>
                <div class="form-group" style="display: flex; align-items: flex-end; padding-bottom: 11px;">
                    <div class="checkbox-group">
                        <input asp-for="IsAvailable" type="checkbox" />
                        <label asp-for="IsAvailable">Đang bán / Còn hàng</label>
                    </div>
                </div>
            </div>

            <hr class="form-divider" />
            <div class="form-section-title">Hình Ảnh Hiện Tại</div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ImageUrl">URL Hình ảnh 1</label>
                    <input asp-for="ImageUrl" class="form-control" />
                </div>
                <div class="form-group">
                    <label asp-for="ImageUrl2">URL Hình ảnh 2</label>
                    <input asp-for="ImageUrl2" class="form-control" />
                </div>
            </div>

            <div class="btn-row">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn-cancel">Hủy</a>
                <a asp-action="Index" class="btn-cancel">← Danh sách</a>
                <button type="submit" class="btn-submit">Lưu Thay Đổi</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}