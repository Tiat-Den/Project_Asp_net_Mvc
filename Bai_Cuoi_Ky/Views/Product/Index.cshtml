@model IEnumerable<Bai_Cuoi_Ky.Models.Product>
@{
    ViewData["Title"] = "Danh Sách Sản Phẩm";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/product_Css/list.css" />

<div class="page-header">
    <h1>Bộ Sưu Tập</h1>
</div>

<div class="container">
    @if (TempData["Success"] != null)
    {
        <div class="alert-success">✓ @TempData["Success"]</div>
    }

    <div style="margin-bottom: 30px; text-align: right;">
        <a asp-action="Create" class="action-btn view" style="padding: 12px 25px;">+ Thêm sản phẩm</a>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="icon">💎</div>
            <p>Hiện chưa có sản phẩm nào trong cửa hàng</p>
        </div>
    }
    else
    {
        <div class="product-grid">
            @foreach (var item in Model)
            {
                <div class="product-card">
                    <span class="card-badge @(!item.IsAvailable ? "out-of-stock" : "")">
                        @if (!item.IsAvailable)
                        {
                            @:Hết hàng
                        }
                        else
                        {
                            @(item.Category != null ? item.Category.Name : "Jewelry")
                        }
                    </span>

                    <div class="card-img-wrap">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img class="card-img img-main" src="@item.ImageUrl" alt="@item.Name" />
                            <img class="card-img img-hover"
                                 src="@(!string.IsNullOrEmpty(item.ImageUrl2) ? item.ImageUrl2 : item.ImageUrl)"
                                 alt="@item.Name" />
                        }
                        else
                        {
                            <div class="card-img-placeholder">💎</div>
                        }
                    </div>

                    <div class="card-body">
                        <div class="card-category">@item.Material</div>
                        <div class="card-name">@item.Name</div>
                        <div class="card-price">
                            <span class="price-main">@item.Price.ToString("N0")₫</span>
                            @if (item.DiscountPrice.HasValue && item.DiscountPrice > 0)
                            {
                                <span class="price-original">@item.DiscountPrice.Value.ToString("N0")₫</span>
                            }
                        </div>
                    </div>

                    <div class="card-footer">
                        <span class="stock-info">Kho: @item.Stock</span>
                        <div class="card-actions">
                            <a class="action-btn view" asp-action="Details" asp-route-id="@item.Id">Xem</a>
                            <a class="action-btn edit" asp-action="Edit" asp-route-id="@item.Id">Sửa</a>
                            <a class="action-btn del" asp-action="Delete" asp-route-id="@item.Id">Xóa</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>