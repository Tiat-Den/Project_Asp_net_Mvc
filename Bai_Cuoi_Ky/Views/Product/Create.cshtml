@model Bai_Cuoi_Ky.Models.Product
@{
    ViewData["Title"] = "Thêm Sản Phẩm";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />

<link rel="stylesheet" href="~/css/product_Css/form.css" />

<div class="form-header">
    <h1>Thêm Sản Phẩm Mới</h1>
</div>

<div class="container">
    <div class="form-card">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="form-section-title">Thông Tin Cơ Bản</div>

            <div class="form-group">
                <label asp-for="Name">Tên sản phẩm *</label>
                <input asp-for="Name" class="form-control" placeholder="VD: Vòng Tay Mặt Trăng Bạc 925" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="CategoryId">Danh mục *</label>
                    <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Material">Chất liệu</label>
                    <input asp-for="Material" class="form-control" placeholder="VD: Bạc 925, Vàng 18K..." />
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Description">Mô tả</label>
                <textarea asp-for="Description" class="form-control" placeholder="Mô tả chi tiết sản phẩm..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <hr class="form-divider" />
            <div class="form-section-title">Giá & Tồn Kho</div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Price">Giá bán (₫) *</label>
                    <input asp-for="Price" type="number" class="form-control" placeholder="350000" min="0" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="DiscountPrice">Giá gốc / Giảm giá (₫)</label>
                    <input asp-for="DiscountPrice" type="number" class="form-control" placeholder="500000" min="0" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Stock">Số lượng tồn kho *</label>
                    <input asp-for="Stock" type="number" class="form-control" placeholder="10" min="0" />
                    <span asp-validation-for="Stock" class="text-danger"></span>
                </div>
                <div class="form-group" style="display: flex; align-items: flex-end; padding-bottom: 11px;">
                    <div class="checkbox-group">
                        <input asp-for="IsAvailable" type="checkbox" />
                        <label asp-for="IsAvailable">Đang bán / Còn hàng</label>
                    </div>
                </div>
            </div>

            <hr class="form-divider" />
            <div class="form-section-title">Hình Ảnh</div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="ImageUrl">URL Hình ảnh 1</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="/images/product1.jpg" />
                </div>
                <div class="form-group">
                    <label asp-for="ImageUrl2">URL Hình ảnh 2</label>
                    <input asp-for="ImageUrl2" class="form-control" placeholder="/images/product2.jpg" />
                </div>
            </div>

            <div class="btn-row">
                <a asp-action="Index" class="btn-cancel">Hủy</a>
                <button type="submit" class="btn-submit">Thêm Sản Phẩm</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}