@model Bai_Cuoi_Ky.Models.Product
@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/product_Css/delete.css" />

<div class="container">
    <div class="delete-wrapper">
        <div class="delete-header">
            <div class="warning-icon">⚠️</div>
            <h1>Xác Nhận Xóa</h1>
            <p>Thao tác này không thể hoàn tác.<br />Sản phẩm sẽ bị xóa vĩnh viễn khỏi hệ thống.</p>
        </div>

        <div class="product-preview">
            <div class="preview-img">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='block';" />
                    <span style="display:none;">💎</span>
                }
                else
                {
                    <span>💎</span>
                }
            </div>
            <div>
                @* Sửa lại: Hiển thị Model.Category.Name thay vì Model.Category *@
                <div class="preview-cat">
                    @(Model.Category != null ? Model.Category.Name : "Chưa phân loại") · @Model.Material
                </div>
                <div class="preview-name">@Model.Name</div>
                <div class="preview-price">@Model.Price.ToString("N0")₫ · Kho: @Model.Stock sản phẩm</div>
            </div>
        </div>

        <div class="warning-note">
            ⚠️ Bạn có chắc chắn muốn xóa sản phẩm <strong>@Model.Name</strong> không?
            Mọi dữ liệu liên quan sẽ bị xóa và không thể khôi phục.
        </div>

        <div class="btn-row">
            <a asp-action="Index" class="btn-cancel">← Hủy Bỏ</a>

            <form asp-action="Delete" method="post" style="flex:1;">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn-delete">🗑 Xóa Vĩnh Viễn</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}