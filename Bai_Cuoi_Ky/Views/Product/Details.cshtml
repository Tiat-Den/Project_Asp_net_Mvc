@model IEnumerable<Bai_Cuoi_Ky.Models.Product>
@{
    ViewData["Title"] = "Sản Phẩm";
}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
<style>
    :root {
        --gold: #c9a84c;
        --cream: #faf8f4;
        --dark: #1a1410;
        --muted: #8a7968;
        --red: #c0392b;
        --border: #e8e8e8;
    }

    body {
        background: var(--cream);
        font-family: 'Jost', sans-serif;
    }

    .page-header {
        text-align: center;
        padding: 48px 0 32px;
    }

        .page-header::before {
            content: '';
            display: block;
            width: 60px;
            height: 1px;
            background: var(--gold);
            margin: 0 auto 16px;
        }

        .page-header h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.8rem;
            font-weight: 300;
            color: var(--dark);
            letter-spacing: 6px;
            text-transform: uppercase;
        }

    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 28px;
        padding-bottom: 60px;
    }

    .product-card {
        background: white;
        position: relative;
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s;
        cursor: pointer;
    }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 48px rgba(0,0,0,0.1);
        }

            .product-card:hover .card-actions {
                opacity: 1;
                transform: translateY(0);
            }

    /* ===== BADGE ===== */
    .card-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: var(--gold);
        color: white;
        font-size: 0.65rem;
        letter-spacing: 1.5px;
        padding: 4px 10px;
        text-transform: uppercase;
        z-index: 10;
    }

        .card-badge.out-of-stock {
            background: #999;
        }

    /* ===== HOVER ĐỔI ẢNH ===== */
    .card-img-wrap {
        position: relative;
        width: 100%;
        height: 280px;
        overflow: hidden;
        background: #f0ece4;
    }

        .card-img-wrap .card-img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: opacity 0.5s ease;
            display: block;
        }

    .img-main {
        opacity: 1;
        z-index: 1;
    }

    .img-hover {
        opacity: 0;
        z-index: 2;
    }

    .product-card:hover .img-main {
        opacity: 0;
    }

    .product-card:hover .img-hover {
        opacity: 1;
    }

    .card-img-placeholder {
        width: 100%;
        height: 280px;
        background: linear-gradient(135deg, #f5f0e8, #ede8de);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: var(--gold);
    }

    .card-body {
        padding: 16px 16px 8px;
    }

    .card-category {
        font-size: 0.65rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 6px;
    }

    .card-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--dark);
        margin-bottom: 8px;
        line-height: 1.4;
    }

    .price-main {
        font-size: 1rem;
        font-weight: 600;
        color: var(--red);
    }

    .price-original {
        font-size: 0.82rem;
        color: #bbb;
        text-decoration: line-through;
        margin-left: 8px;
    }

    .card-footer {
        padding: 0 16px 16px;
    }

    .card-actions {
        opacity: 0;
        transform: translateY(8px);
        transition: all 0.25s;
    }

    .action-btn {
        display: block;
        width: 100%;
        padding: 10px;
        text-align: center;
        font-size: 0.72rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: 'Jost', sans-serif;
        background: var(--dark);
        color: white;
        transition: background 0.2s;
    }

        .action-btn:hover {
            background: var(--gold);
            color: white;
            text-decoration: none;
        }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
        color: var(--muted);
    }

        .empty-state p {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.4rem;
        }
</style>

<div class="page-header">
    <h1>Danh Sách Sản Phẩm</h1>
</div>

<div style="max-width:1400px;margin:0 auto;padding:0 40px;">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <p>Chưa có sản phẩm nào</p>
        </div>
    }
    else
    {
        <div class="product-grid">
            @foreach (var item in Model)
            {
                <div class="product-card">

                    <!-- BADGE -->
                    @if (!item.IsAvailable)
                    {
                        <span class="card-badge out-of-stock">Hết hàng</span>
                    }
                    else
                    {
                        <span class="card-badge">@item.Category</span>
                    }

                    <!-- ẢNH -->
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <div class="card-img-wrap">
                            <img class="card-img img-main" src="@item.ImageUrl" alt="@item.Name" />
                            <img class="card-img img-hover"
                                 src="@(!string.IsNullOrEmpty(item.ImageUrl2) ? item.ImageUrl2 : item.ImageUrl)"
                                 alt="@item.Name" />
                        </div>
                    }
                    else
                    {
                        <div class="card-img-placeholder">💎</div>
                    }

                    <!-- THÔNG TIN -->
                    <div class="card-body">
                        <div class="card-category">@item.Material</div>
                        <div class="card-name">@item.Name</div>
                        <div>
                            <span class="price-main">@item.Price.ToString("N0")₫</span>
                            @if (item.DiscountPrice.HasValue)
                            {
                                <span class="price-original">@item.DiscountPrice.Value.ToString("N0")₫</span>
                            }
                        </div>
                    </div>

                    <!-- NÚT XEM CHI TIẾT -->
                    <div class="card-footer">
                        <div class="card-actions">
                            <a class="action-btn" href="@Url.Action("Details", new { id = item.Id })">Xem Chi Tiết →</a>
                        </div>
                    </div>

                </div>
            }
        </div>
    }
</div>