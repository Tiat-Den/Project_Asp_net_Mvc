@model Bai_Cuoi_Ky.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/product_Css/detail.css" />

<div class="container">
    <div class="breadcrumb-bar">
        <a asp-action="Index">Sản phẩm</a>
        <span>›</span>
        @* Sửa: Sử dụng Model.Category.Id và Model.Category.Name *@
        <a asp-action="Index" asp-route-categoryId="@Model.CategoryId">
            @(Model.Category != null ? Model.Category.Name : "Danh mục")
        </a>
        <span>›</span>
        @Model.Name
    </div>

    <div class="detail-layout">
        <div class="detail-img">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='block';" />
                <span style="display:none;">💎</span>
            }
            else
            {
                <span>💎</span>
            }
        </div>

        <div>
            @* Sửa: Hiển thị tên danh mục thật *@
            <div class="detail-category">@(Model.Category != null ? Model.Category.Name : "Chưa phân loại")</div>
            <h1 class="detail-name">@Model.Name</h1>
            <div class="divider"></div>

            <div style="margin-bottom:28px;">
                <span class="price-current">@Model.Price.ToString("N0")₫</span>
                @if (Model.DiscountPrice.HasValue && Model.DiscountPrice > 0)
                {
                    <span class="price-old">@Model.DiscountPrice.Value.ToString("N0")₫</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="desc-block">@Model.Description</div>
            }

            <table class="meta-table">
                <tr><td>Chất liệu</td><td>@(Model.Material ?? "—")</td></tr>
                @* Sửa: Hiển thị tên danh mục trong bảng thông số *@
                <tr><td>Danh mục</td><td>@(Model.Category != null ? Model.Category.Name : "—")</td></tr>
                <tr><td>Tồn kho</td><td>@Model.Stock sản phẩm</td></tr>
                <tr>
                    <td>Trạng thái</td>
                    <td>
                        <span class="stock-badge @(Model.IsAvailable ? "in-stock" : "out-stock")">
                            @(Model.IsAvailable ? "Còn hàng" : "Hết hàng")
                        </span>
                    </td>
                </tr>
            </table>

            <a href="javascript:void(0);" onclick="history.back();" class="btn-outline">← Quay Lại</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}