@model Bai_Cuoi_Ky.Models.Product
@{
    ViewData["Title"] = Model.Name + " - Chi Tiết Sản Phẩm";
}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="~/css/product_Css/detail.css" />

<style>

    @@media (max-width: 768px) {
        .detail-grid {
            grid-template-columns: 1fr;
            gap: 32px;
        }

        .detail-images {
            position: static;
        }

        .detail-name {
            font-size: 1.6rem;
        }
    }
</style>

<div class="detail-container">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <span>›</span>
        <a asp-controller="Product" asp-action="Index">Sản phẩm</a>
        <span>›</span>
        @Model.Name
    </div>

    <div class="detail-grid">

        <!-- CỘT TRÁI: ẢNH -->
        <div class="detail-images">
            <div class="main-image-wrap">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img id="mainImage" src="@Model.ImageUrl" alt="@Model.Name" />
                }
                else
                {
                    <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:4rem;color:var(--gold);">💎</div>
                }
            </div>
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="thumb-row">
                    <div class="thumb active" onclick="changeImage('@Model.ImageUrl', this)">
                        <img src="@Model.ImageUrl" alt="Ảnh 1" />
                    </div>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl2))
                    {
                        <div class="thumb" onclick="changeImage('@Model.ImageUrl2', this)">
                            <img src="@Model.ImageUrl2" alt="Ảnh 2" />
                        </div>
                    }
                </div>
            }
        </div>

        <!-- CỘT PHẢI: THÔNG TIN -->
        <div class="detail-info">
            <div class="detail-category">@(Model.Category?.Name ?? "Trang sức")</div>
            <h1 class="detail-name">@Model.Name</h1>

            <!-- GIÁ -->
            <div class="detail-price-row">
                <span class="detail-price">@Model.Price.ToString("N0")₫</span>
                @if (Model.DiscountPrice.HasValue)
                {
                    <span class="detail-price-old">@Model.DiscountPrice.Value.ToString("N0")₫</span>
                    int percent = (int)((Model.DiscountPrice.Value - Model.Price) / Model.DiscountPrice.Value * 100);
                    if (percent > 0)
                    {
                        <span class="detail-discount-badge">Giảm @percent%</span>
                    }
                }
            </div>

            <!-- THÔNG SỐ -->
            <div class="detail-specs">
                <div class="spec-item">
                    <span class="detail-label">Chất liệu</span>
                    <span class="detail-value">@(Model.Material ?? "Chưa cập nhật")</span>
                </div>
                <div class="spec-item">
                    <span class="detail-label">Danh mục</span>
                    <span class="detail-value">@(Model.Category?.Name ?? "Chưa phân loại")</span>
                </div>
                <div class="spec-item">
                    <span class="detail-label">Tồn kho</span>
                    <span class="detail-value">@Model.Stock sản phẩm</span>
                </div>
                <div class="spec-item">
                    <span class="detail-label">Tình trạng</span>
                    <span class="availability">
                        @if (Model.IsAvailable)
                        {
                            <span class="avail-dot in-stock"></span>
                            <span style="color:#27ae60;">Còn hàng</span>
                        }
                        else
                        {
                            <span class="avail-dot out-of-stock"></span>
                            <span style="color:#e74c3c;">Hết hàng</span>
                        }
                    </span>
                </div>
            </div>

            <!-- MÔ TẢ -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="detail-section">
                    <div class="detail-label">Mô tả sản phẩm</div>
                    <div class="detail-value">@Model.Description</div>
                </div>
            }

            <!-- NÚT HÀNH ĐỘNG -->
            <div class="btn-group">
                <a class="btn-primary-custom" asp-controller="Product" asp-action="Index">← Quay Lại</a>
                <button type="button"
                        class="btn-outline-custom ajax-add-to-cart"
                        data-id="@Model.Id">
                    🛒 Thêm Vào Giỏ
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeImage(src, el) {
            document.getElementById('mainImage').src = src;
            document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }
    </script>
}