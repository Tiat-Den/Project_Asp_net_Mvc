@model Bai_Cuoi_Ky.Models.Product
@{
    ViewData["Title"] = Model.Name + " - Chi Tiết Sản Phẩm";
}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
<style>
    :root {
        --gold: #c9a84c;
        --cream: #faf8f4;
        --dark: #1a1410;
        --muted: #8a7968;
        --red: #c0392b;
        --border: #e8e8e8;
    }

    body {
        background: var(--cream);
        font-family: 'Jost', sans-serif;
    }

    .detail-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 40px 80px;
    }

    .breadcrumb {
        font-size: 0.78rem;
        color: var(--muted);
        margin-bottom: 32px;
        letter-spacing: 1px;
    }

        .breadcrumb a {
            color: var(--muted);
            text-decoration: none;
            transition: color 0.2s;
        }

            .breadcrumb a:hover {
                color: var(--gold);
            }

        .breadcrumb span {
            margin: 0 8px;
        }

    .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: start;
    }

    /* ===== IMAGE ===== */
    .detail-images {
        position: sticky;
        top: 20px;
    }

    .main-image-wrap {
        width: 100%;
        aspect-ratio: 1/1;
        overflow: hidden;
        background: #f0ece4;
        position: relative;
    }

        .main-image-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: opacity 0.5s ease;
        }

    .thumb-row {
        display: flex;
        gap: 12px;
        margin-top: 12px;
    }

    .thumb {
        width: 80px;
        height: 80px;
        overflow: hidden;
        cursor: pointer;
        border: 2px solid transparent;
        transition: border-color 0.2s;
        background: #f0ece4;
    }

        .thumb:hover,
        .thumb.active {
            border-color: var(--gold);
        }

        .thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* ===== INFO ===== */
    .detail-info {
        padding-top: 8px;
    }

    .detail-category {
        font-size: 0.7rem;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 12px;
    }

    .detail-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.2rem;
        font-weight: 400;
        color: var(--dark);
        line-height: 1.3;
        margin-bottom: 20px;
    }

    .detail-price-row {
        display: flex;
        align-items: baseline;
        gap: 16px;
        margin-bottom: 28px;
        padding-bottom: 28px;
        border-bottom: 1px solid var(--border);
    }

    .detail-price {
        font-size: 1.6rem;
        font-weight: 600;
        color: var(--red);
    }

    .detail-price-old {
        font-size: 1rem;
        color: #bbb;
        text-decoration: line-through;
    }

    .detail-discount-badge {
        background: var(--red);
        color: white;
        font-size: 0.68rem;
        letter-spacing: 1px;
        padding: 4px 10px;
        text-transform: uppercase;
    }

    .detail-section {
        margin-bottom: 24px;
    }

    .detail-label {
        font-size: 0.72rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 8px;
    }

    .detail-value {
        font-size: 0.95rem;
        color: var(--dark);
        line-height: 1.7;
    }

    .detail-specs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 28px;
        padding-bottom: 28px;
        border-bottom: 1px solid var(--border);
    }

    .spec-item {
        display: flex;
        flex-direction: column;
    }

    .availability {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.85rem;
    }

    .avail-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

        .avail-dot.in-stock {
            background: #27ae60;
        }

        .avail-dot.out-of-stock {
            background: #e74c3c;
        }

    .btn-group {
        display: flex;
        gap: 12px;
        margin-top: 32px;
    }

    .btn-primary-custom {
        flex: 1;
        padding: 14px 24px;
        background: var(--dark);
        color: white;
        text-align: center;
        font-size: 0.75rem;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        text-decoration: none;
        border: none;
        cursor: pointer;
        font-family: 'Jost', sans-serif;
        transition: background 0.3s;
    }

        .btn-primary-custom:hover {
            background: var(--gold);
            color: white;
            text-decoration: none;
        }

    .btn-outline-custom {
        padding: 14px 24px;
        background: transparent;
        color: var(--dark);
        text-align: center;
        font-size: 0.75rem;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        text-decoration: none;
        border: 1px solid var(--border);
        cursor: pointer;
        font-family: 'Jost', sans-serif;
        transition: all 0.3s;
    }

        .btn-outline-custom:hover {
            border-color: var(--gold);
            color: var(--gold);
            text-decoration: none;
        }

    @@media (max-width: 768px) {
        .detail-grid {
            grid-template-columns: 1fr;
            gap: 32px;
        }

        .detail-images {
            position: static;
        }

        .detail-name {
            font-size: 1.6rem;
        }
    }
</style>

<div class="detail-container">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <span>›</span>
        <a asp-controller="Product" asp-action="Index">Sản phẩm</a>
        <span>›</span>
        @Model.Name
    </div>

    <div class="detail-grid">

        <!-- CỘT TRÁI: ẢNH -->
        <div class="detail-images">
            <div class="main-image-wrap">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img id="mainImage" src="@Model.ImageUrl" alt="@Model.Name" />
                }
                else
                {
                    <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:4rem;color:var(--gold);">💎</div>
                }
            </div>
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="thumb-row">
                    <div class="thumb active" onclick="changeImage('@Model.ImageUrl', this)">
                        <img src="@Model.ImageUrl" alt="Ảnh 1" />
                    </div>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl2))
                    {
                        <div class="thumb" onclick="changeImage('@Model.ImageUrl2', this)">
                            <img src="@Model.ImageUrl2" alt="Ảnh 2" />
                        </div>
                    }
                </div>
            }
        </div>

        <!-- CỘT PHẢI: THÔNG TIN -->
        <div class="detail-info">
            <div class="detail-category">@(Model.Category?.Name ?? "Trang sức")</div>
            <h1 class="detail-name">@Model.Name</h1>

            <!-- GIÁ -->
            <div class="detail-price-row">
                <span class="detail-price">@Model.Price.ToString("N0")₫</span>
                @if (Model.DiscountPrice.HasValue)
                {
                    <span class="detail-price-old">@Model.DiscountPrice.Value.ToString("N0")₫</span>
                    int percent = (int)((Model.DiscountPrice.Value - Model.Price) / Model.DiscountPrice.Value * 100);
                    if (percent > 0)
                    {
                        <span class="detail-discount-badge">Giảm @percent%</span>
                    }
                }
            </div>

            <!-- THÔNG SỐ -->
            <div class="detail-specs">
                <div class="spec-item">
                    <span class="detail-label">Chất liệu</span>
                    <span class="detail-value">@(Model.Material ?? "Chưa cập nhật")</span>
                </div>
                <div class="spec-item">
                    <span class="detail-label">Danh mục</span>
                    <span class="detail-value">@(Model.Category?.Name ?? "Chưa phân loại")</span>
                </div>
                <div class="spec-item">
                    <span class="detail-label">Tồn kho</span>
                    <span class="detail-value">@Model.Stock sản phẩm</span>
                </div>
                <div class="spec-item">
                    <span class="detail-label">Tình trạng</span>
                    <span class="availability">
                        @if (Model.IsAvailable)
                        {
                            <span class="avail-dot in-stock"></span>
                            <span style="color:#27ae60;">Còn hàng</span>
                        }
                        else
                        {
                            <span class="avail-dot out-of-stock"></span>
                            <span style="color:#e74c3c;">Hết hàng</span>
                        }
                    </span>
                </div>
            </div>

            <!-- MÔ TẢ -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="detail-section">
                    <div class="detail-label">Mô tả sản phẩm</div>
                    <div class="detail-value">@Model.Description</div>
                </div>
            }

            <!-- NÚT HÀNH ĐỘNG -->
            <div class="btn-group">
                <a class="btn-primary-custom" asp-controller="Product" asp-action="Index">← Quay Lại</a>
                <a class="btn-outline-custom" asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id">Chỉnh Sửa</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function changeImage(src, el) {
            document.getElementById('mainImage').src = src;
            document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }
    </script>
}