@model Bai_Cuoi_Ky.Models.Product
@{
    ViewData["Title"] = Model.Name;
}
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
<style>
    :root {
        --gold: #c9a84c;
        --gold-light: #e8d5a3;
        --cream: #faf8f4;
        --dark: #1a1410;
        --muted: #8a7968;
    }

    body {
        background: var(--cream);
        font-family: 'Jost', sans-serif;
    }

    .breadcrumb-bar {
        padding: 20px 0;
        font-size: 0.75rem;
        letter-spacing: 1px;
        color: var(--muted);
    }

        .breadcrumb-bar a {
            color: var(--muted);
            text-decoration: none;
        }

            .breadcrumb-bar a:hover {
                color: var(--gold);
            }

        .breadcrumb-bar span {
            margin: 0 8px;
        }

    .detail-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        padding: 20px 0 60px;
    }
    /* ĐÚNG */
    @@media(max-width:768px) {
        .detail-layout {
            grid-template-columns: 1fr;
            gap: 32px;
        }
    }

    .detail-img {
        aspect-ratio: 1;
        background: linear-gradient(135deg, #f5f0e8, #ede8de);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 5rem;
        overflow: hidden;
    }

        .detail-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .detail-category {
        font-size: 0.7rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 12px;
    }

    .detail-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.4rem;
        font-weight: 300;
        color: var(--dark);
        line-height: 1.2;
        margin-bottom: 24px;
    }

    .divider {
        width: 40px;
        height: 1px;
        background: var(--gold);
        margin-bottom: 24px;
    }

    .price-current {
        font-size: 2rem;
        font-weight: 500;
        color: var(--dark);
    }

    .price-old {
        font-size: 1rem;
        color: #bbb;
        text-decoration: line-through;
        margin-left: 12px;
    }

    .meta-table {
        width: 100%;
        border-collapse: collapse;
        margin: 20px 0 28px;
    }

        .meta-table td {
            padding: 10px 0;
            border-bottom: 1px solid #ede8e0;
            font-size: 0.88rem;
        }

            .meta-table td:first-child {
                width: 130px;
                color: var(--muted);
                font-size: 0.72rem;
                letter-spacing: 1.5px;
                text-transform: uppercase;
            }

            .meta-table td:last-child {
                color: var(--dark);
                font-weight: 500;
            }

    .stock-badge {
        display: inline-block;
        padding: 3px 12px;
        font-size: 0.72rem;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .in-stock {
        background: #e8f5e9;
        color: #2e7d32;
    }

    .out-stock {
        background: #fce4e4;
        color: #c62828;
    }

    .desc-block {
        background: white;
        padding: 20px;
        border-left: 3px solid var(--gold-light);
        font-size: 0.9rem;
        line-height: 1.7;
        color: var(--muted);
        margin-bottom: 32px;
    }

    .action-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-primary {
        background: var(--dark);
        color: white;
        padding: 13px 32px;
        font-family: 'Jost', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: background 0.2s;
        display: inline-block;
    }

        .btn-primary:hover {
            background: var(--gold);
            color: white;
            text-decoration: none;
        }

    .btn-outline {
        background: white;
        color: var(--dark);
        border: 1px solid #ddd;
        padding: 13px 32px;
        font-family: 'Jost', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-block;
    }

        .btn-outline:hover {
            border-color: var(--dark);
            text-decoration: none;
            color: var(--dark);
        }

    .btn-danger {
        background: white;
        color: #c62828;
        border: 1px solid #c62828;
        padding: 13px 32px;
        font-family: 'Jost', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-block;
    }

        .btn-danger:hover {
            background: #c62828;
            color: white;
            text-decoration: none;
        }
</style>

<div class="container">
    <div class="breadcrumb-bar">
        <a href="@Url.Action("Index")">Sản phẩm</a>
        <span>›</span>
        <a href="@Url.Action("Index", new { category = Model.Category })">@Model.Category</a>
        <span>›</span>
        @Model.Name
    </div>

    <div class="detail-layout">
        <div class="detail-img">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='block';" />
                <span style="display:none;">💎</span>
            }
            else
            {

                <span>💎</span>
            }
        </div>

        <div>
            <div class="detail-category">@Model.Category</div>
            <h1 class="detail-name">@Model.Name</h1>
            <div class="divider"></div>

            <div style="margin-bottom:28px;">
                <span class="price-current">@Model.Price.ToString("N0")₫</span>
                @if (Model.DiscountPrice.HasValue)
                {
                    <span class="price-old">@Model.DiscountPrice.Value.ToString("N0")₫</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="desc-block">@Model.Description</div>
            }

            <table class="meta-table">
                <tr><td>Chất liệu</td><td>@(Model.Material ?? "—")</td></tr>
                <tr><td>Danh mục</td><td>@Model.Category</td></tr>
                <tr><td>Tồn kho</td><td>@Model.Stock sản phẩm</td></tr>
                <tr>
                    <td>Trạng thái</td>
                    <td>
                        <span class="stock-badge @(Model.IsAvailable ? "in-stock" : "out-stock")">
                            @(Model.IsAvailable ? "Còn hàng" : "Hết hàng")
                        </span>
                    </td>
                </tr>
                <tr><td>Ngày tạo</td><td>@Model.CreatedAt.ToString("dd/MM/yyyy")</td></tr>
            </table>

            <div class="action-row">
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn-primary">Chỉnh Sửa</a>
                <a href="@Url.Action("Index")" class="btn-outline">← Quay Lại</a>
                <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn-danger">Xóa</a>
            </div>
        </div>
    </div>
</div>