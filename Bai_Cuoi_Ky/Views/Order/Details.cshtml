@model Bai_Cuoi_Ky.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom">
                <h5 class="mb-0 py-2">Sản phẩm trong đơn hàng</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end pe-3">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in Model.OrderDetails)
                            {
                                <tr>
                                    <td class="ps-3 text-primary fw-bold">
                                        @(detail.Product?.Name ?? "Sản phẩm không xác định")
                                    </td>
                                    <td class="text-center">@detail.Quantity</td>
                                    <td class="text-end">@detail.UnitPrice.ToString("N0") VNĐ</td>
                                    <td class="text-end pe-3">@((detail.Quantity * detail.UnitPrice).ToString("N0")) VNĐ</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Tổng cộng:</td>
                                <td class="text-end pe-3 fw-bold text-danger fs-5">@Model.TotalAmount.ToString("N0") VNĐ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom">
                <h5 class="mb-0 py-2">Thông tin khách hàng</h5>
            </div>
            <div class="card-body">
                <p><strong><i class="fas fa-user text-muted me-2"></i></strong> @Model.CustomerName</p>
                <p><strong><i class="fas fa-phone-alt text-muted me-2"></i></strong> @Model.PhoneNumber</p>
                <p><strong><i class="fas fa-envelope text-muted me-2"></i></strong> @Model.Email</p>
                <p><strong><i class="fas fa-map-marker-alt text-muted me-2"></i></strong> @Model.Address</p>
                <p><strong><i class="far fa-calendar-alt text-muted me-2"></i></strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom">
                <h5 class="mb-0 py-2">Cập nhật trạng thái</h5>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show p-2 text-center" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close py-1" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="mb-3 text-center">
                    <p class="mb-2">Trạng thái hiện tại:</p>
                    @if (Model.Status == "ChoXuLy")
                    {
                        <span class="badge bg-warning text-dark fs-6 px-3 py-2">Chờ xử lý</span>
                    }
                    else if (Model.Status == "HoanThanh")
                    {
                        <span class="badge bg-success fs-6 px-3 py-2">Hoàn thành</span>
                    }
                    else if (Model.Status == "DaHuy")
                    {
                        <span class="badge bg-danger fs-6 px-3 py-2">Đã hủy</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary fs-6 px-3 py-2">@Model.Status</span>
                    }
                </div>

                <form asp-action="UpdateStatus" method="post" class="d-grid gap-2">
                    <input type="hidden" name="id" value="@Model.Id" />
                    
                    @if (Model.Status == "ChoXuLy")
                    {
                        <button type="submit" name="status" value="HoanThanh" class="btn btn-success">
                            <i class="fas fa-check-circle"></i> Xác nhận Hoàn thành
                        </button>
                        <button type="submit" name="status" value="DaHuy" class="btn btn-outline-danger">
                            <i class="fas fa-times-circle"></i> Hủy đơn hàng
                        </button>
                    }
                    else if (Model.Status == "HoanThanh" || Model.Status == "DaHuy")
                    {
                        <button type="submit" name="status" value="ChoXuLy" class="btn btn-outline-warning">
                            <i class="fas fa-undo"></i> Đặt lại thành Chờ xử lý
                        </button>
                    }
                </form>
                
                <div class="mt-4 text-center">
                    <a asp-action="Index" class="text-decoration-none text-secondary"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>
                </div>
            </div>
        </div>
    </div>
</div>
